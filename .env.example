# ── env vars ──────────────────────────────────────────────────────────────────
# Copy to .env and edit before running `docker compose up`

# InfluxDB
INFLUX_USER=admin
INFLUX_PASSWORD=changeme123
INFLUX_ORG=controller
INFLUX_BUCKET=process
INFLUX_TOKEN=super-secret-token-change-me

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme123

# Controller
CONTROLLER_PROFILE=electrolysis
LOG_LEVEL=INFO

# Timezone (used by Node-RED and logs)
TZ=UTC
